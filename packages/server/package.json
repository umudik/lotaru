{
  "name": "@lotaru/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "src/main.ts",
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json && node ../../scripts/cp-schema.mjs",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "chokidar": "^4.0.1",
    "dockerode": "^5.0.1",
    "fastify": "^5.8.5",
    "micromatch": "^4.0.8",
    "nanoid": "^5.0.9",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
