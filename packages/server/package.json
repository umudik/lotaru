{
  "name": "@lotaru/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "src/main.ts",
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json && node ../../scripts/cp-schema.mjs",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "dockerode": "^4.0.2",
    "fastify": "^4.28.1",
    "micromatch": "^4.0.8",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^3.3.32",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
