{
  "name": "@umudik/lotaru-mcp",
  "version": "0.1.1",
  "private": false,
  "description": "MCP server for Lotaru — create and run tasks from Cursor",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umudik/lotaru.git",
    "directory": "packages/mcp"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lotaru-mcp": "dist/index.js"
  },
  "files": [
